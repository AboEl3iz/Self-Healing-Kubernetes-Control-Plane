{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "eBPF signal ingestion rate, anomaly confidence scores, false positive rates, and multi-signal correlation effectiveness.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "\ud83d\udce1 Signal Ingestion",
      "type": "row",
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 2,
      "type": "stat",
      "title": "Signals / min",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(selfheal_anomalies_detected_total[1m]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 3,
      "type": "stat",
      "title": "False Positives / hr",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(selfheal_false_positives_total{namespace=~\"$namespace\"}[1h]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 4,
      "type": "stat",
      "title": "Suppressions / hr",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "yellow",
            "mode": "fixed"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(selfheal_false_positives_total{namespace=~\"$namespace\", reason=\"low_confidence\"}[1h]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 5,
      "type": "stat",
      "title": "Cooldown Blocks / hr",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(selfheal_false_positives_total{namespace=~\"$namespace\", reason=\"cooldown\"}[1h]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 6,
      "title": "\ud83d\udcca Confidence Distribution",
      "type": "row",
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 7,
      "type": "timeseries",
      "title": "Anomaly Detection Rate by Rule",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (rule, decision)(rate(selfheal_anomalies_detected_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{rule}} / {{decision}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 8,
      "type": "timeseries",
      "title": "Confidence Score Histogram (P50 / P90 / P99)",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.50, sum by (le,rule)(rate(selfheal_confidence_score_bucket{namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "{{rule}} p50",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.90, sum by (le,rule)(rate(selfheal_confidence_score_bucket{namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "{{rule}} p90",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.99, sum by (le,rule)(rate(selfheal_confidence_score_bucket{namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "{{rule}} p99",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 9,
      "title": "\ud83d\udd17 Multi-Signal Correlation",
      "type": "row",
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 10,
      "type": "timeseries",
      "title": "False Positive Rate by Reason",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (reason)(rate(selfheal_false_positives_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 11,
      "type": "timeseries",
      "title": "Actions Dispatched vs Suppressed",
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(selfheal_actions_dispatched_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "dispatched",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(selfheal_false_positives_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "suppressed",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": [
    "selfheal",
    "signal-quality",
    "ebpf",
    "confidence"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Data Source"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(selfheal_anomalies_detected_total, namespace)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "name": "namespace",
        "options": [],
        "query": {
          "query": "label_values(selfheal_anomalies_detected_total, namespace)",
          "refId": "S"
        },
        "refresh": 2,
        "type": "query",
        "label": "Namespace"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "SelfHeal \u2014 Signal Quality",
  "uid": "selfheal-signal-quality-v1",
  "version": 1
}