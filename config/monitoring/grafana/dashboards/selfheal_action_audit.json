          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (action, resolution_type)(rate(selfheal_actions_resolved_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{action}} / {{resolution_type}}",
          "refId": "A"
