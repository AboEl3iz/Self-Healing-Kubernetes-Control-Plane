{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Cluster-wide healing activity, node health scores, root cause attribution, and action success rates.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "\ud83c\udfe5 Healing Overview",
      "type": "row",
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 2,
      "type": "stat",
      "title": "Active Anomalies",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(selfheal_anomalies_detected_total{namespace=~\"$namespace\"}[10m]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 3,
      "type": "stat",
      "title": "Actions / hr",
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(selfheal_actions_dispatched_total{namespace=~\"$namespace\"}[1h]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 4,
      "type": "stat",
      "title": "Healing Success Rate",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(selfheal_actions_resolved_total{namespace=~\"$namespace\", resolution_type=\"immediate\"}[1h])) / clamp_min(sum(rate(selfheal_actions_dispatched_total{namespace=~\"$namespace\"}[1h])), 1) * 100",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 5,
      "type": "stat",
      "title": "Circuit Breaker",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "selfheal_circuit_breaker_open",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 6,
      "type": "stat",
      "title": "Node Incidents / hr",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(selfheal_node_incidents_total[1h]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 7,
      "type": "stat",
      "title": "Nodes Below Health Threshold",
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "dark-red",
            "mode": "fixed"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(selfheal_node_health_score < 0.4)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 8,
      "title": "\ud83d\udcc8 Node Health Scores",
      "type": "row",
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 9,
      "type": "timeseries",
      "title": "Node Health Score (by node)",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "selfheal_node_health_score",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 10,
      "title": "\ud83d\udd25 Action Rate",
      "type": "row",
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 11,
      "type": "timeseries",
      "title": "Healing Actions / min (by action)",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (action)(rate(selfheal_actions_dispatched_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 12,
      "type": "timeseries",
      "title": "Anomaly Detection Rate (by rule)",
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (rule)(rate(selfheal_anomalies_detected_total{namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{rule}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "id": 13,
      "title": "\ud83d\udd2c Root Cause Distribution",
      "type": "row",
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 14,
      "type": "timeseries",
      "title": "Incidents by Root Cause",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (root_cause)(rate(selfheal_node_incidents_total[$__rate_interval]))",
          "legendFormat": "{{root_cause}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 15,
      "type": "timeseries",
      "title": "Root Cause Confidence (by node)",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "selfheal_node_incident_confidence",
          "legendFormat": "{{node}} / {{root_cause}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 16,
      "title": "\ud83d\udccb Top Problematic Pods",
      "type": "row",
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 17,
      "type": "table",
      "title": "Anomaly Count by Pod (last 1h)",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "topk(20, sum by (pod, namespace)(increase(selfheal_anomalies_detected_total{namespace=~\"$namespace\"}[1h])))",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {}
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": [
    "selfheal",
    "kubernetes",
    "healing",
    "cluster"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Data Source"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(selfheal_anomalies_detected_total, namespace)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "name": "namespace",
        "options": [],
        "query": {
          "query": "label_values(selfheal_anomalies_detected_total, namespace)",
          "refId": "S"
        },
        "refresh": 2,
        "type": "query",
        "label": "Namespace"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "SelfHeal \u2014 Cluster Health Overview",
  "uid": "selfheal-cluster-health-v1",
  "version": 1
}